# ── Required for Phase 1 ──────────────────────────────────
NASA_FIRMS_KEY=        # https://firms.modaps.eosdis.nasa.gov/api/map_key/

# ── Required for Phase 2 ─────────────────────────────────
OPENAQ_API_KEY=        # https://explore.openaq.org → register
NASA_API_KEY=          # https://api.nasa.gov → generate key

# ── Optional Phase 2 sources ─────────────────────────────
OPENWEATHER_KEY=       # https://openweathermap.org/api
TOMORROW_KEY=          # https://app.tomorrow.io

# ── Aggregator config ─────────────────────────────────────
CACHE_TTL_SECONDS=300
DEFAULT_RADIUS_KM=500
LOG_LEVEL=info

# ── MCP Server ────────────────────────────────────────────
MCP_PORT=3000
MCP_TRANSPORT=http     # stdio | http

# ── Logs ──────────────────────────────────────────────────
LOG_DIR=./logs
