# ── API Keys (all optional — more keys = more layers) ────
NASA_FIRMS_KEY=        # https://firms.modaps.eosdis.nasa.gov/api/map_key/ (fire hotspots)
OPENAQ_API_KEY=        # https://explore.openaq.org → register (physical AQ stations)

# ── Aggregator config ─────────────────────────────────────
CACHE_TTL_SECONDS=300
DEFAULT_RADIUS_KM=500
LOG_LEVEL=info

# ── MCP Server ────────────────────────────────────────────
MCP_PORT=3000
MCP_TRANSPORT=http     # stdio | http
MCP_ALLOWED_ORIGINS=   # comma-separated origins for CORS

# ── Logs ──────────────────────────────────────────────────
LOG_DIR=./logs
